{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "analytics": "cdc2479e-f372-4394-84d2-bf003e098bee"
  },
  "newProjectRoot": ".",
  "projects": {
    "blockflow": {
      "projectType": "library",
      "root": "blockflow",
      "sourceRoot": "blockflow/src",
      "prefix": "bf",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "path": "blockflow/src/blocks",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "path": "packages/src/core",
          "skipTests": true
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "blockflow/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "blockflow/tsconfig.lib.prod.json",
            },
            "development": {
              "tsConfig": "blockflow/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "blockflow/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "demo",
      "sourceRoot": "demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/demo",
            "index": "demo/src/index.html",
            "main": "demo/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "demo/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "demo/src/favicon.ico",
              "demo/src/assets"
            ],
            "styles": [
              "demo/src/styles.scss",
              "blockflow/src/assets/iconfont/bf-iconfont.css",
              "blockflow/src/assets/styles/editor.scss",
              "node_modules/viewerjs/dist/viewer.min.css",
              "node_modules/ng-zorro-antd/ng-zorro-antd.min.css",
              "blockcraft/themes/light.scss",
              "blockcraft/assets/iconfont/bc-iconfont.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "demo:build:production"
            },
            "development": {
              "browserTarget": "demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "demo:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "demo/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "demo/src/favicon.ico",
              "demo/src/assets"
            ],
            "styles": [
              "demo/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "blockcraft": {
      "projectType": "library",
      "root": "blockcraft",
      "sourceRoot": "blockcraft",
      "prefix": "blockcraft",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "blockcraft/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "blockcraft/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "blockcraft/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "blockcraft/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  }
}
