{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "analytics": "e719eec9-13a0-476d-975b-73bd9635918b"
  },
  "newProjectRoot": ".",
  "projects": {
    "playground": {
      "projectType": "application",
      "root": "apps/playground",
      "sourceRoot": "apps/playground/src",
      "prefix": "bc",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/playground",
            "index": "apps/playground/src/index.html",
            "main": "apps/playground/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/playground/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "apps/playground/src/assets"
            ],
            "styles": [
              "apps/playground/src/styles.scss",
              "node_modules/viewerjs/dist/viewer.min.css",
              "node_modules/ng-zorro-antd/ng-zorro-antd.min.css",
              "packages/editor/themes/base.scss",
              "packages/editor/themes/light.scss",
              "packages/editor/themes/dark.scss",
              "packages/editor/assets/iconfont/bc-iconfont.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "12kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "playground:build:production"
            },
            "development": {
              "buildTarget": "playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "editor": {
      "projectType": "library",
      "root": "packages/editor",
      "sourceRoot": "packages/editor",
      "prefix": "blockcraft",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "packages/editor/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "packages/editor/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "packages/editor/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "packages/editor/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  }
}
