{
  "name": "blockflow",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "demo": "ng serve demo --open --configuration development --port 8081 --host 0.0.0.0",
    "build": "ng build blockflow && pnpm copy-assets",
    "copy-assets": "cpx 'blockflow/src/assets/**/*' dist/blockflow-editor/assets",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "pub": "ng build blockflow && pnpm copy-assets && cd dist/blockflow-editor && npm publish --registry http://npm.runtongqiuben.com",
    "unpub": "npm unpublish @w/blockflow-editor --force --registry http://npm.runtongqiuben.com"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.3.12",
    "@angular/core": "^17.3.12",
    "@angular/forms": "^17.3.12",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "@angular/router": "^17.3.12",
    "@babel/core": "^7.25.2",
    "@ctrl/tinycolor": "^4.1.0",
    "@types/prettier": "^3.0.0",
    "@types/prismjs": "^1.26.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "cpx": "^1.5.0",
    "dompurify": "^3.2.1",
    "file-type": "^20.4.1",
    "mermaid": "^11.4.0",
    "nanoid": "^5.1.2",
    "ng-zorro-antd": "^17.4.1",
    "prettier": "^3.5.3",
    "prismjs": "^1.29.0",
    "quill-delta": "^5.1.0",
    "quill-delta-from-html": "^1.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "viewerjs": "^1.11.6",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.18",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.11",
    "@angular/cli": "~17.3.11",
    "@angular/compiler-cli": "^17.3.12",
    "@types/jasmine": "~5.1.4",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "madge": "^8.0.0",
    "ng-packagr": "^17.3.0",
    "typescript": "5.4.5"
  }
}
