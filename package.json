{
  "name": "blockflow",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "demo": "ng serve demo --open --configuration development --port 8081 --host 0.0.0.0",
    "build": "ng build blockflow && pnpm run copy-assets",
    "copy-assets": "cpx 'blockflow/src/assets/**/*' dist/blockflow/assets",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "pub": "pnpm build && pnpm copy-assets && cd dist/blockflow && npm publish --registry https://npm.runtongqiuben.com"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^16.0.0",
    "@angular/cdk": "16.2.14",
    "@angular/common": "^16.0.0",
    "@angular/compiler": "^16.0.0",
    "@angular/core": "^16.0.0",
    "@angular/forms": "^16.0.0",
    "@angular/material": "16.2.14",
    "@angular/platform-browser": "^16.0.0",
    "@angular/platform-browser-dynamic": "^16.0.0",
    "@angular/router": "^16.0.0",
    "@babel/core": "^7.25.2",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@emoji-mart/data": "^1.2.1",
    "@types/codemirror": "5.60.15",
    "@types/rangy": "^0.0.38",
    "add": "^2.0.6",
    "babel-plugin-module-resolver": "^5.0.2",
    "cpx": "^1.5.0",
    "highlight.js": "^11.10.0",
    "ng-zorro-antd": "16.2.0",
    "ngx-lightbox": "^3.0.0",
    "ngx-virtual-scroller": "^4.0.3",
    "rangy": "^1.3.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "viewerjs": "^1.11.6",
    "y-protocols": "^1.0.6",
    "y-webrtc": "^10.3.0",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.18",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.0.6",
    "@angular/cli": "~16.0.3",
    "@angular/compiler-cli": "^16.0.0",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ng-packagr": "^16.0.0",
    "typescript": "~5.0.2"
  }
}
